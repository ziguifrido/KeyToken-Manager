{
  "manifest_version": 3,
  "name": "KeyToken Manager",
  "version": "1.0.0",
  "description": "Obtém e gerencia Access Tokens do Keycloak (OpenID Connect)",
  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
